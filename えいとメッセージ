<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LABORICK</title>
<style>
body{ margin:0; background:#ffffff; }
canvas{ display:block; margin:0 auto; background:#ffffff; touch-action:manipulation;}
</style>
</head>
<body>
<canvas id="c"></canvas>

<script>
const canvas = document.getElementById("c");
const ctx = canvas.getContext("2d");

let w = window.innerWidth;
let h = window.innerHeight;
canvas.width = w;
canvas.height = h;

let s = w / 300; // スマホ縦画面を優先し、幅に基づくスケールに変更
let stage = 0;
let breathTime = 0;

let messageVisible = false;
  
// アバター定義
const avatar = { 
  x: w/2, 
  y: h/2 + 40*s, 
  scale: s, 
  final: false  // 最終形態で呼吸を開始するフラグ
};
// 服のカラーを茶色に
const dominant = { color: "#8B4513" }; // 茶色に変更


// 素材（棒や蝶）
let balls = [];
let spawnCount = 0;

function spawnBall(){
  balls.push({
    x: Math.random()*w,
    y: h + 50*s,
    r: 16*s,
    active: true,
    vy: - (1 + Math.random()*1) * s, // 速度をスケールに比例させ、縦画面での移動時間を適切に調整
    absorbed: false,
    angle: 0
  });
  spawnCount++;
}

spawnBall();

// 金粉（星）
let sparkles = [];
function createSparkles(mult=1){
  
  messageVisible = true;
  
  for(let i=0;i<120*mult;i++){
    let baseSize = (Math.random()*3 + 1)*s;
    if(Math.random() < 0.2) baseSize *= 2.5;

    sparkles.push({
      x: w/2 + (Math.random()-0.5)*120*s,
      y: h/2 + (Math.random()-0.5)*120*s,
      size: baseSize,
      alpha: 1,
      vx: (Math.random()-0.5)*2*s,
      vy: -Math.random()*3*s,
      life: 10
    });
  }
}

// 星を描く関数
function drawStar(ctx, cx, cy, outerRadius, points, inset){
  const step = Math.PI / points;
  ctx.beginPath();
  for(let i = 0; i < 2*points; i++){
    const r = (i%2 === 0) ? outerRadius : outerRadius*inset;
    const a = i*step - Math.PI/2;
    ctx.lineTo(cx + r*Math.cos(a), cy + r*Math.sin(a));
  }
  ctx.closePath();
  ctx.fill();
}

  
// 棒人間を描く関数（白固定）
function drawAvatar(){
  const a = avatar, s = a.scale;
  ctx.lineWidth=2*s; ctx.strokeStyle="#000"; ctx.fillStyle="#fff";

  // 頭
  ctx.beginPath();
  ctx.arc(a.x,a.y-32*s,12*s,0,Math.PI*2);
  ctx.fill(); ctx.stroke();

  // 胴体
  ctx.fillRect(a.x-7*s,a.y-18*s,14*s,44*s);
  ctx.strokeRect(a.x-7*s,a.y-18*s,14*s,44*s);

  // 袖
  ctx.fillRect(a.x-28*s,a.y-4*s,20*s,6*s);
  ctx.fillRect(a.x+8*s,a.y-4*s,20*s,6*s);
  ctx.strokeRect(a.x-28*s,a.y-4*s,20*s,6*s);
  ctx.strokeRect(a.x+8*s,a.y-4*s,20*s,6*s);

  // 手
  ctx.fillRect(a.x-7*s,a.y+24*s,7*s,26*s);
  ctx.fillRect(a.x+2*s,a.y+24*s,7*s,26*s);
  ctx.strokeRect(a.x-7*s,a.y+24*s,7*s,26*s);
  ctx.strokeRect(a.x+2*s,a.y+24*s,7*s,26*s);
}

// 服描画（最終形態）
function drawClothes(){
  if(!dominant) return;
  const a = avatar, s = a.scale;
  ctx.fillStyle = dominant.color; ctx.strokeStyle="#333"; ctx.lineWidth=2*s;

  ctx.beginPath();
  ctx.roundRect(a.x-24*s,a.y-28*s,48*s,64*s,14*s);
  ctx.fill(); ctx.stroke();

  ctx.beginPath();
  ctx.roundRect(a.x-42*s,a.y-16*s,18*s,26*s,7*s);
  ctx.roundRect(a.x+24*s,a.y-16*s,18*s,26*s,7*s);
  ctx.fill(); ctx.stroke();

  ctx.fillStyle="#fff";
  ctx.font=`bold ${12*s}px Arial`;
  ctx.textAlign="center"; ctx.textBaseline="middle";
  ctx.fillText("MIZUKI", a.x, a.y);
}

// ===== メイン描画 =====
function draw(){
  ctx.clearRect(0,0,w,h);

  // ===== 呼吸 =====
  breathTime += 0.01;
  let amplitude = 0, speed = 0;
  if(stage === 2 && avatar.final){
    amplitude = 9*s;   // 振れ幅をスケールに比例
    speed = 0.11;    // 呼吸速度
  }
  const breathOffset = Math.sin(breathTime / speed) * amplitude;
  avatar.y = h/2 + 40*s + (stage===2 && avatar.final ? breathOffset : 0);

  // ===== アバター描画 =====
  if(stage===0) {
    // 白丸
    ctx.fillStyle = "#fff"; ctx.strokeStyle = "#000"; ctx.lineWidth=2*s;
    ctx.beginPath();
    ctx.arc(avatar.x,avatar.y,15*s,0,Math.PI*2);
    ctx.fill(); ctx.stroke();
  }
  else if(stage===1){
    // 白い棒人間
    drawAvatar();
  }
  else if(stage===2){
    // 最終形態：棒人間+服
    drawAvatar();
    drawClothes();
  }

  // ===== 素材（棒・蝶）描画と吸収 =====
  balls.forEach(ball=>{
    if(!ball.active) return;
    if(!ball.absorbed && stage!==1) ball.y += ball.vy;

    ctx.beginPath();
    if(stage===0){
      // 棒
      const stickWidth = 4*s, stickHeight = 30*s;
      ctx.rect(ball.x-stickWidth/2, ball.y-stickHeight/2, stickWidth, stickHeight);
      ctx.strokeStyle="#000"; ctx.stroke();
    }
    else if(stage===1){
      // 蝶
      const size = ball.r;
      const baseX = avatar.x, baseY = avatar.y-110*s;
      const floatOffset = Math.sin(Date.now()*0.003)*8*s;
      const drawY = baseY + floatOffset;
     // ===== 蝶を描く部分 =====
ctx.fillStyle = dominant ? dominant.color : "#fff"; // 茶色
ctx.strokeStyle = "#000"; // 輪郭は黒

      // 左三角
      ctx.beginPath();
      ctx.moveTo(baseX, drawY);
      ctx.lineTo(baseX-size, drawY-size);
      ctx.lineTo(baseX-size, drawY+size);
      ctx.closePath();
      ctx.fill(); ctx.stroke();

      // 右三角
      ctx.beginPath();
      ctx.moveTo(baseX, drawY);
      ctx.lineTo(baseX+size, drawY-size);
      ctx.lineTo(baseX+size, drawY+size);
      ctx.closePath();
      ctx.fill(); ctx.stroke();

      if(!ball.absorbed){ ball.x=baseX; ball.y=drawY; }
    }
    else {
  // ステージ2: 🏓絵文字
  ctx.font = `${ball.r * 2}px serif`; // サイズを四角形の幅に合わせる（調整可能）
  ctx.textAlign = "center"; // 横中央揃え
  ctx.textBaseline = "middle"; // 縦中央揃え
  ctx.fillStyle = "#000"; // 絵文字の色（任意で変更可、例: dominant.colorに合わせる）
  ctx.fillText("🏓", ball.x, ball.y); // 絵文字を描画
  // 必要に応じて輪郭を追加（元のストローク相当）
  ctx.strokeStyle = "#000";
  ctx.strokeText("🏓", ball.x, ball.y);
}

    // ===== 吸収判定 =====
    const dx = avatar.x-ball.x, dy=avatar.y-ball.y;
    const dist = Math.sqrt(dx*dx+dy*dy);
    let absorbDistance = stage===1 ? 40*s : 100*s; // 距離もスケールに比例

    if(dist<absorbDistance || ball.absorbed){
      ball.absorbed=true;
      ball.x += dx*0.03; ball.y += dy*0.03;

      if("vibrate" in navigator) navigator.vibrate([50]);

      let finished=false;
      if(stage===1){
        if(ball.r<2*s) finished=true;
        else ball.r*=0.97;
      } else {
        if(dist<10*s) finished=true;
      }

      if(finished){
        ball.active=false;
        if(stage<2 && spawnCount<3){
          spawnBall(); stage++;
        } else if(stage===2 && !avatar.final){
          createSparkles(2);
          avatar.final=true;
        }
      }
    }
  });


// ===== 金粉（💩マーク）描画 =====
sparkles.forEach((sp,i)=>{
    ctx.globalAlpha=sp.alpha;
    ctx.fillStyle="gold"; // 金色
    ctx.font = `${sp.size*2}px serif`; // サイズ調整
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";
    ctx.fillText("💩", sp.x, sp.y); // 絵文字で描画
    ctx.globalAlpha=1;

    sp.x+=sp.vx; sp.y+=sp.vy;
    sp.life-=1/60; sp.alpha=sp.life/10;
    if(sp.life<=0) sparkles.splice(i,1);
});

  // ===== メッセージ =====
  if(messageVisible && sparkles.length > 0){

    ctx.fillStyle = "#000";
    ctx.font = `bold ${20*s}px serif`;
    ctx.textAlign = "center";
    ctx.textBaseline = "middle";

    ctx.fillText("テストおつかれさま", w/2, h/2 - 80*s);

  }

}

// ===== アニメーション開始 =====
function animate(){ draw(); requestAnimationFrame(animate); }
animate();

// リサイズ対応（スマホ回転時など）
window.addEventListener('resize', () => {
  w = window.innerWidth;
  h = window.innerHeight;
  canvas.width = w;
  canvas.height = h;
  s = w / 300; // 縦画面優先で幅ベース
  avatar.x = w / 2;
  avatar.scale = s;
});

// ===== タッチで吸収（スマホ対応） =====
canvas.addEventListener("touchstart", e => {
  e.preventDefault();
  const rect = canvas.getBoundingClientRect();
  for (let i = 0; i < e.touches.length; i++) {
    const touch = e.touches[i];
    const x = touch.clientX - rect.left;
    const y = touch.clientY - rect.top;
    balls.forEach(ball => {
      if (!ball.active) return;
      const dist = Math.sqrt((x - ball.x) ** 2 + (y - ball.y) ** 2);
      if (stage === 1) {
        if (dist < 40 * s) ball.absorbed = true;
      } else {
        if (dist < ball.r) ball.absorbed = true;
      }
    });
  }
});

// PC対応でclickも追加
canvas.addEventListener("click", e => {
  const rect = canvas.getBoundingClientRect();
  const x = e.clientX - rect.left;
  const y = e.clientY - rect.top;
  balls.forEach(ball => {
    if (!ball.active) return;
    const dist = Math.sqrt((x - ball.x) ** 2 + (y - ball.y) ** 2);
    if (stage === 1) {
      if (dist < 40 * s) ball.absorbed = true;
    } else {
      if (dist < ball.r) ball.absorbed = true;
    }
  });
});
</script>
</body>
</html>
